# BMS host stack configuration template
# Copy to .env (optional) and/or set these variables in your shell.

# API service
BMS_API_PORT=8090
BMS_STOP_EXISTING=1
BMS_STARTUP_RETRIES=15
BMS_STARTUP_DELAY_SEC=1
BMS_DB_RETENTION_DAYS=7
BMS_DB_RETENTION_INTERVAL_MIN=60

# Simulator
BMS_SIM_COUNT=120
BMS_SIM_INTERVAL_MS=1000

# UI
WEB_UI_PORT=8088
GUI_API_BASE=http://127.0.0.1:8090
GUI_INPUT_MODE=api

# Database (easy settings; service also accepts BMS_DB_URL / BMS_DB_USER / BMS_DB_PASS)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bms
DB_USER=root
DB_PASSWORD=

# Optional explicit JDBC override (takes priority when set)
# BMS_DB_URL=jdbc:mysql://127.0.0.1:3306/bms?useSSL=false&allowPublicKeyRetrieval=true
# BMS_DB_USER=root
# BMS_DB_PASS=

# Capture mode helper (informational connectivity check)
RPI_HOST=192.168.1.50
BMS_RPI_OFFLINE_SECONDS=30
