# API service
BMS_API_PORT=8090
BMS_STOP_EXISTING=1
BMS_STARTUP_RETRIES=15
BMS_STARTUP_DELAY_SEC=1
BMS_DB_RETENTION_DAYS=7
BMS_DB_RETENTION_INTERVAL_MIN=60

# Simulator
BMS_SIM_COUNT=120
BMS_SIM_INTERVAL_MS=1000

# UI
WEB_UI_PORT=8088
GUI_API_BASE=http://127.0.0.1:8090
GUI_INPUT_MODE=api

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=bms
DB_USER=root
DB_PASSWORD=

# UART sender
SERIAL_PORT=SIMULATED
SERIAL_BAUD=115200
DEFAULT_MODULE_ID=1
BMS_API_INGEST_URL=http://127.0.0.1:8090/api/ingest
TINYBMS_POLL_INTERVAL_MS=2000

# Optional connectivity check
RPI_HOST=192.168.1.50
BMS_RPI_OFFLINE_SECONDS=30
